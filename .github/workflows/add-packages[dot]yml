name: Update Bucket Listings
on:
  push:
    paths:
      - 'bucket/**'
  workflow_dispatch:

jobs:
  update-listings:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4

      - name: Update Files
        shell: python
        run: |
          import os
          import json
          import re

          # Find app manifests in bucket
          apps = sorted([f.replace('.json', '') for f in os.listdir('bucket') if f.endswith('.json')])

          # Update App Database
          os.makedirs('site', exist_ok=True)
          with open('site/apps.js', 'w') as f:
              f.write("// GitHub Bot will Append to this list on push to bucket dir in repo\n")
              f.write(f"export const appList = {json.dumps(apps, indent=2)};")

          # Update README
          if os.path.exists('README.md'):
              with open('README.md', 'r') as f:
                  content = f.read()
              
              readme_list = "\n".join([f"- [{app}](bucket/{app}.json)" for app in apps])
              pattern = r'()(.*?)()'
              new_content = re.sub(pattern, f"\\1\n{readme_list}\n\\3", content, flags=re.DOTALL)
              
              with open('README.md', 'w') as f:
                  f.write(new_content)

      - name: Commit and Push
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add README.md site/apps.js
          git commit -m "chore: update package listings" || exit 0
          git push
